# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/gitverify
MONGODB_AUTO_INDEX=true

# GitHub API
GITHUB_TOKEN=

# Scoring Weights (ATS)
ATS_ALPHA=0.60
ATS_BETA=0.40
FINAL_LAMBDA=0.50

# Scoring Weights (GitHub)
GITHUB_ACTIVITY_WEIGHT=0.20
GITHUB_LANGUAGE_WEIGHT=0.20
GITHUB_QUALITY_WEIGHT=0.20
GITHUB_CONSISTENCY_WEIGHT=0.20
GITHUB_VERIFICATION_WEIGHT=0.20

# Limits
MAX_RESUME_FILE_SIZE_MB=10
MAX_FILES_PER_UPLOAD=20
API_RATE_LIMIT_PER_MINUTE=60
